PORT=4000
NODE_ENV=development
SERVICE_NAME="medicai-backend"
LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_STACKS=false
TRUST_PROXY=false
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medicai"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
RESEND_API_KEY="re_xxxxxxxxx"
MAIL_FROM="MedicAI <soporte@medicai.lat>"
# URL pública que aparece en los correos: botón y enlace alternativo.
# Debe apuntar al dominio público de MedicAI, no al servidor/funnel.
APP_BASE_URL="https://medicai.lat"
APP_DEEP_LINK_BASE_URL="medicai://auth"
ALLOWED_ORIGINS="https://medicai.lat,http://localhost:8081,http://localhost:19000,http://localhost:3000"
