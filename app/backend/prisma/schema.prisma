generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                   @id @default(cuid())
  email            String                   @unique
  fullName         String?
  birthDate        String?
  phone            String?
  passwordHash     String
  isEmailVerified  Boolean                  @default(false)
  refreshTokenHash String?
  avatar           String?
  conditions       String?
  allergies        String?
  pregnancy        Boolean                  @default(false)
  lactation        Boolean                  @default(false)
  recentSurgeries  Boolean                  @default(false)
  immunosuppression Boolean                 @default(false)
  anticoagulantTreatment Boolean            @default(false)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  verificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  medications        Medication[]
  appointments       Appointment[]
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Medication {
  id           String   @id @default(cuid())
  userId       String
  name         String
  dosage       String
  frequency    String
  times        String[] // Array of "HH:mm" strings
  notes        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs MedicationLog[]

  @@index([userId])
  @@index([createdAt])
}

model MedicationLog {
  id           String   @id @default(cuid())
  medicationId String
  action       String   // "TAKEN", "SKIPPED", "SNOOZED"
  takenAt      DateTime @default(now())
  
  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId])
  @@index([takenAt])
}

model Appointment {
  id          String   @id @default(cuid())
  userId      String
  title       String
  doctorName  String
  scheduledAt DateTime
  location    String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
  @@index([createdAt])
}
